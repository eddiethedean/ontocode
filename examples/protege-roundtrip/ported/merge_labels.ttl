@prefix ex: <http://example.org/merge#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Ontology a owl:Ontology .

ex:Keep a owl:Class ;
    rdfs:label "Keep" .

ex:Merge a owl:Class ;
    rdfs:label "MergeLabel" .

ex:Child a owl:Class ;
    rdfs:subClassOf ex:Merge .
