{
  "name": "ontocode",
  "displayName": "OntoCode",
  "description": "Ontology IDE for VS Code powered by OntoCore. Browse, edit Turtle, query, reason (EL–DL), validate, and diff OWL/RDF/OBO ontologies from the IDE or CI.",
  "version": "0.17.0",
  "publisher": "ontocode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eddiethedean/ontocode.git"
  },
  "homepage": "https://ontocode-vs.readthedocs.io/en/latest/guides/first-success/",
  "bugs": {
    "url": "https://github.com/eddiethedean/ontocode/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0078D4",
    "theme": "dark"
  },
  "keywords": [
    "ontology",
    "owl",
    "rdf",
    "turtle",
    "obo",
    "protege",
    "sparql",
    "semantic web",
    "knowledge graph",
    "ontocore",
    "explorer",
    "diagnostics",
    "linter",
    "validate",
    "reasoner",
    "manchester",
    "cursor"
  ],
  "activationEvents": [
    "workspaceContains:**/*.ttl",
    "workspaceContains:**/*.owl",
    "workspaceContains:**/*.owx",
    "workspaceContains:**/*.rdf",
    "workspaceContains:**/*.jsonld",
    "workspaceContains:**/*.json-ld",
    "workspaceContains:**/*.nt",
    "workspaceContains:**/*.nq",
    "workspaceContains:**/*.trig",
    "workspaceContains:**/*.obo",
    "onView:ontocode.explorer.ontologies"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "obo",
        "aliases": [
          "OBO",
          "obo"
        ],
        "extensions": [
          ".obo"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "obo",
        "scopeName": "source.obo",
        "path": "./syntaxes/obo.tmLanguage.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ontocode",
          "title": "OntoCode",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ontocode": [
        {
          "id": "ontocode.explorer.ontologies",
          "name": "Ontologies"
        },
        {
          "id": "ontocode.explorer.classes",
          "name": "Classes"
        },
        {
          "id": "ontocode.explorer.properties",
          "name": "Properties"
        },
        {
          "id": "ontocode.explorer.individuals",
          "name": "Individuals"
        },
        {
          "id": "ontocode.explorer.diagnostics",
          "name": "Diagnostics"
        }
      ]
    },
    "commands": [
      {
        "command": "ontocode.indexWorkspace",
        "title": "OntoCode: Index Workspace",
        "icon": "$(refresh)"
      },
      {
        "command": "ontocode.refreshExplorer",
        "title": "OntoCode: Refresh Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "ontocode.showEntityInspector",
        "title": "OntoCode: Show Entity Inspector"
      },
      {
        "command": "ontocode.jumpToSource",
        "title": "OntoCode: Jump to Source"
      },
      {
        "command": "ontocode.openDiagnostic",
        "title": "OntoCode: Open Diagnostic"
      },
      {
        "command": "ontocode.openEntity",
        "title": "Open Entity Inspector"
      },
      {
        "command": "ontocode.createClass",
        "title": "OntoCode: Create Class"
      },
      {
        "command": "ontocode.createProperty",
        "title": "OntoCode: Create Property"
      },
      {
        "command": "ontocode.createIndividual",
        "title": "OntoCode: Create Individual"
      },
      {
        "command": "ontocode.deleteEntity",
        "title": "OntoCode: Delete Entity"
      },
      {
        "command": "ontocode.openQueryWorkbench",
        "title": "OntoCode: Open Query Workbench"
      },
      {
        "command": "ontocode.openManchesterEditor",
        "title": "OntoCode: Open Manchester Editor"
      },
      {
        "command": "ontocode.addManchesterAxiom",
        "title": "OntoCode: Add Manchester Axiom"
      },
      {
        "command": "ontocode.runReasoner",
        "title": "OntoCode: Run Reasoner"
      },
      {
        "command": "ontocode.runOwlmakeWorkflow",
        "title": "OntoCode: Run Workflow (owlmake)"
      },
      {
        "command": "ontocode.plugins.runCommand",
        "title": "OntoCode: Plugins: Run Command…"
      },
      {
        "command": "ontocode.plugins.openView",
        "title": "OntoCode: Plugins: Open View…"
      },
      {
        "command": "ontocode.plugins.openPreferences",
        "title": "OntoCode: Plugins: Open Preferences…"
      },
      {
        "command": "ontocode.plugins.runContextAction",
        "title": "OntoCode: Plugins: Run Context Action…"
      },
      {
        "command": "ontocode.semanticDiff",
        "title": "OntoCode: Semantic Diff…"
      },
      {
        "command": "ontocode.showExplanation",
        "title": "OntoCode: Show Explanation"
      },
      {
        "command": "ontocode.setHierarchyMode",
        "title": "OntoCode: Set Hierarchy Mode"
      },
      {
        "command": "ontocode.openClassGraph",
        "title": "OntoCode: Open Class Graph"
      },
      {
        "command": "ontocode.openPropertyGraph",
        "title": "OntoCode: Open Property Graph"
      },
      {
        "command": "ontocode.openImportGraph",
        "title": "OntoCode: Open Import Graph"
      },
      {
        "command": "ontocode.manageImports",
        "title": "OntoCode: Manage Imports"
      },
      {
        "command": "ontocode.reloadImports",
        "title": "OntoCode: Reload Imports"
      },
      {
        "command": "ontocode.resetLayout",
        "title": "OntoCode: Reset Layout"
      },
      {
        "command": "ontocode.openNeighborhoodGraph",
        "title": "OntoCode: Open Neighborhood Graph"
      },
      {
        "command": "ontocode.openGraph",
        "title": "OntoCode: Open Graph"
      },
      {
        "command": "ontocode.findEntityUsages",
        "title": "OntoCode: Find Entity Usages"
      },
      {
        "command": "ontocode.renameEntityIri",
        "title": "OntoCode: Rename Entity IRI"
      },
      {
        "command": "ontocode.migrateNamespace",
        "title": "OntoCode: Migrate Namespace"
      },
      {
        "command": "ontocode.moveEntity",
        "title": "OntoCode: Move Entity"
      },
      {
        "command": "ontocode.extractModule",
        "title": "OntoCode: Extract Module"
      },
      {
        "command": "ontocode.newOntology",
        "title": "OntoCode: New Ontology",
        "icon": "$(new-file)"
      },
      {
        "command": "ontocode.openOntology",
        "title": "OntoCode: Open Ontology"
      },
      {
        "command": "ontocode.openRecent",
        "title": "OntoCode: Open Recent"
      },
      {
        "command": "ontocode.save",
        "title": "OntoCode: Save"
      },
      {
        "command": "ontocode.saveAll",
        "title": "OntoCode: Save All"
      },
      {
        "command": "ontocode.undo",
        "title": "OntoCode: Undo"
      },
      {
        "command": "ontocode.redo",
        "title": "OntoCode: Redo"
      },
      {
        "command": "ontocode.saveAs",
        "title": "OntoCode: Save Ontology As…"
      },
      {
        "command": "ontocode.exportOntology",
        "title": "OntoCode: Export Ontology…"
      },
      {
        "command": "ontocode.closeProject",
        "title": "OntoCode: Close Project"
      },
      {
        "command": "ontocode.searchEntities",
        "title": "OntoCode: Search Entities",
        "icon": "$(search)"
      },
      {
        "command": "ontocode.openPreferences",
        "title": "OntoCode: Open Preferences",
        "icon": "$(settings-gear)"
      },
      {
        "command": "ontocode.copyEntityIri",
        "title": "OntoCode: Copy Entity IRI"
      },
      {
        "command": "ontocode.copyEntityShortForm",
        "title": "OntoCode: Copy Entity Short Form"
      },
      {
        "command": "ontocode.setActiveOntology",
        "title": "OntoCode: Set Active Ontology"
      },
      {
        "command": "ontocode.editOntologyMetadata",
        "title": "OntoCode: Edit Ontology Metadata"
      },
      {
        "command": "ontocode.managePrefixes",
        "title": "OntoCode: Manage Prefixes"
      },
      {
        "command": "ontocode.showMetrics",
        "title": "OntoCode: Show Metrics",
        "icon": "$(graph)"
      },
      {
        "command": "ontocode.mergeEntities",
        "title": "OntoCode: Merge Entities"
      },
      {
        "command": "ontocode.replaceEntity",
        "title": "OntoCode: Replace Entity"
      },
      {
        "command": "ontocode.startReasoner",
        "title": "OntoCode: Start Reasoner"
      },
      {
        "command": "ontocode.stopReasoner",
        "title": "OntoCode: Stop Reasoner"
      },
      {
        "command": "ontocode.synchronizeReasoner",
        "title": "OntoCode: Synchronize Reasoner",
        "icon": "$(sync)"
      },
      {
        "command": "ontocode.classifyOntology",
        "title": "OntoCode: Classify Ontology"
      },
      {
        "command": "ontocode.checkConsistency",
        "title": "OntoCode: Check Consistency"
      },
      {
        "command": "ontocode.configureReasoner",
        "title": "OntoCode: Configure Reasoner"
      },
      {
        "command": "ontocode.validateWorkspace",
        "title": "OntoCode: Validate Workspace"
      },
      {
        "command": "ontocode.runBatchTools",
        "title": "OntoCode: Run Batch Tools"
      },
      {
        "command": "ontocode.switchPerspective",
        "title": "OntoCode: Switch Perspective"
      },
      {
        "command": "ontocode.savePerspective",
        "title": "OntoCode: Save Perspective"
      },
      {
        "command": "ontocode.showInspectorPanel",
        "title": "OntoCode: Show Inspector Panel"
      },
      {
        "command": "ontocode.showQueryPanel",
        "title": "OntoCode: Show Query Panel"
      },
      {
        "command": "ontocode.showReasonerPanel",
        "title": "OntoCode: Show Reasoner Panel"
      },
      {
        "command": "ontocode.showExplanationPanel",
        "title": "OntoCode: Show Explanation Panel"
      },
      {
        "command": "ontocode.showGraphPanel",
        "title": "OntoCode: Show Graph Panel"
      },
      {
        "command": "ontocode.showSemanticDiffPanel",
        "title": "OntoCode: Show Semantic Diff Panel"
      },
      {
        "command": "ontocode.showImportsPanel",
        "title": "OntoCode: Show Imports Panel"
      },
      {
        "command": "ontocode.showAbout",
        "title": "OntoCode: About"
      },
      {
        "command": "ontocode.showPluginInfo",
        "title": "OntoCode: Plugin Information"
      },
      {
        "command": "ontocode.openErrorLog",
        "title": "OntoCode: Open Error Log"
      },
      {
        "command": "ontocode.exportDiagnostics",
        "title": "OntoCode: Export Diagnostics"
      },
      {
        "command": "ontocode.openDocumentation",
        "title": "OntoCode: Open Documentation"
      },
      {
        "command": "ontocode.openSupport",
        "title": "OntoCode: Open Support"
      },
      {
        "command": "ontocode.openKeyboardShortcuts",
        "title": "OntoCode: Open Keyboard Shortcuts"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ontocode.refreshExplorer",
          "when": "view =~ /^ontocode\\.explorer\\./",
          "group": "navigation"
        },
        {
          "command": "ontocode.newOntology",
          "when": "view =~ /^ontocode\\.explorer\\./",
          "group": "navigation@1"
        },
        {
          "command": "ontocode.searchEntities",
          "when": "view =~ /^ontocode\\.explorer\\./ && ontocode:hasOntology",
          "group": "navigation@2"
        },
        {
          "command": "ontocode.synchronizeReasoner",
          "when": "view =~ /^ontocode\\.explorer\\./ && ontocode:hasOntology",
          "group": "navigation@3"
        },
        {
          "command": "ontocode.showMetrics",
          "when": "view =~ /^ontocode\\.explorer\\./ && ontocode:hasOntology",
          "group": "navigation@4"
        },
        {
          "command": "ontocode.openPreferences",
          "when": "view =~ /^ontocode\\.explorer\\./",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "ontocode.jumpToSource",
          "when": "view =~ /^ontocode\\.explorer\\./ && viewItem == ontocodeEntity",
          "group": "navigation"
        },
        {
          "command": "ontocode.openEntity",
          "when": "view =~ /^ontocode\\.explorer\\./ && viewItem == ontocodeEntity",
          "group": "inline"
        },
        {
          "command": "ontocode.openNeighborhoodGraph",
          "when": "view =~ /^ontocode\\.explorer\\./ && viewItem == ontocodeEntity",
          "group": "navigation"
        },
        {
          "command": "ontocode.openGraph",
          "when": "view =~ /^ontocode\\.explorer\\./ && viewItem == ontocodeEntity",
          "group": "navigation"
        },
        {
          "command": "ontocode.findEntityUsages",
          "when": "view =~ /^ontocode\\.explorer\\./ && viewItem == ontocodeEntity",
          "group": "2_edit"
        },
        {
          "command": "ontocode.renameEntityIri",
          "when": "view =~ /^ontocode\\.explorer\\./ && viewItem == ontocodeEntity",
          "group": "2_edit"
        },
        {
          "command": "ontocode.deleteEntity",
          "when": "view =~ /^ontocode\\.explorer\\./ && viewItem == ontocodeEntity",
          "group": "2_edit"
        },
        {
          "command": "ontocode.manageImports",
          "when": "view == ontocode.explorer.ontologies && viewItem == ontocodeTurtleDocument",
          "group": "2_edit"
        },
        {
          "command": "ontocode.createClass",
          "when": "view == ontocode.explorer.classes",
          "group": "navigation"
        },
        {
          "command": "ontocode.createIndividual",
          "when": "view == ontocode.explorer.individuals",
          "group": "navigation"
        },
        {
          "command": "ontocode.createProperty",
          "when": "view == ontocode.explorer.properties",
          "group": "navigation"
        },
        {
          "command": "ontocode.copyEntityIri",
          "when": "view =~ /^ontocode\\.explorer\\./ && viewItem == ontocodeEntity",
          "group": "3_copy"
        },
        {
          "command": "ontocode.copyEntityShortForm",
          "when": "view =~ /^ontocode\\.explorer\\./ && viewItem == ontocodeEntity",
          "group": "3_copy"
        },
        {
          "command": "ontocode.mergeEntities",
          "when": "view =~ /^ontocode\\.explorer\\./ && viewItem == ontocodeEntity",
          "group": "2_edit"
        },
        {
          "command": "ontocode.replaceEntity",
          "when": "view =~ /^ontocode\\.explorer\\./ && viewItem == ontocodeEntity",
          "group": "2_edit"
        }
      ],
      "editor/title": [
        {
          "command": "ontocode.newOntology",
          "group": "navigation@1"
        },
        {
          "command": "ontocode.searchEntities",
          "when": "ontocode:hasOntology",
          "group": "navigation@2"
        },
        {
          "command": "ontocode.synchronizeReasoner",
          "when": "ontocode:hasOntology",
          "group": "navigation@3"
        },
        {
          "command": "ontocode.showMetrics",
          "when": "ontocode:hasOntology",
          "group": "navigation@4"
        },
        {
          "command": "ontocode.openPreferences",
          "group": "navigation@5"
        }
      ],
      "explorer/context": [
        {
          "command": "ontocode.openOntology",
          "group": "ontocode@1"
        },
        {
          "command": "ontocode.newOntology",
          "group": "ontocode@2"
        }
      ],
      "commandPalette": [
        {
          "command": "ontocode.saveAs",
          "when": "ontocode:hasOntology"
        },
        {
          "command": "ontocode.exportOntology",
          "when": "ontocode:hasOntology"
        },
        {
          "command": "ontocode.searchEntities",
          "when": "ontocode:hasOntology"
        },
        {
          "command": "ontocode.copyEntityIri",
          "when": "ontocode:hasSelection"
        },
        {
          "command": "ontocode.copyEntityShortForm",
          "when": "ontocode:hasSelection"
        },
        {
          "command": "ontocode.mergeEntities",
          "when": "ontocode:hasSelection && ontocode:canEditSelection"
        },
        {
          "command": "ontocode.replaceEntity",
          "when": "ontocode:hasSelection && ontocode:canEditSelection"
        },
        {
          "command": "ontocode.stopReasoner",
          "when": "ontocode:reasonerRunning"
        },
        {
          "command": "ontocode.startReasoner",
          "when": "ontocode:hasOntology && !ontocode:reasonerRunning"
        },
        {
          "command": "ontocode.validateWorkspace",
          "when": "ontocode:hasOntology"
        },
        {
          "command": "ontocode.exportDiagnostics",
          "when": "ontocode:hasOntology"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ontocode.searchEntities",
        "key": "ctrl+k ctrl+e",
        "mac": "cmd+k cmd+e",
        "when": "ontocode:hasOntology"
      },
      {
        "command": "ontocode.openClassGraph",
        "key": "ctrl+g",
        "mac": "cmd+g",
        "when": "ontocode:hasOntology"
      },
      {
        "command": "ontocode.showExplanation",
        "key": "ctrl+e",
        "mac": "cmd+e",
        "when": "ontocode:hasSelection"
      },
      {
        "command": "ontocode.synchronizeReasoner",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "ontocode:hasOntology"
      },
      {
        "command": "ontocode.showEntityInspector",
        "key": "ctrl+3",
        "mac": "cmd+3",
        "when": "ontocode:hasOntology"
      }
    ],
    "configuration": {
      "title": "OntoCode",
      "properties": {
        "ontocode.lspPath": {
          "type": "string",
          "default": "",
          "description": "Trusted workspaces only: path to the ontocore-lsp binary. Ignored in Restricted Mode. When empty, the bundled server or PATH is used."
        },
        "ontocode.autoIndexOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Legacy no-op. Indexing is driven by the language server on workspace open; kept for compatibility with older settings."
        },
        "ontocode.queryHistoryLimit": {
          "type": "number",
          "default": 20,
          "description": "Maximum number of recent queries kept in the Query Workbench history."
        },
        "ontocode.reasoner.default": {
          "type": "string",
          "enum": [
            "el",
            "rl",
            "rdfs",
            "dl",
            "auto"
          ],
          "default": "el",
          "description": "Default reasoner profile for Run Reasoner (el, rl, rdfs, dl, auto)."
        },
        "ontocode.reasoner.autoProfile": {
          "type": "boolean",
          "default": true,
          "description": "Emit profile-detection warnings when running the reasoner."
        },
        "ontocode.hierarchy.mode": {
          "type": "string",
          "enum": [
            "asserted",
            "inferred",
            "combined"
          ],
          "default": "asserted",
          "description": "Class hierarchy display mode in the explorer after classification."
        },
        "ontocode.indexCache": {
          "type": "boolean",
          "default": false,
          "description": "Persist ontology parse snapshots under .ontocore/cache/ (recommended gitignore)."
        },
        "ontocode.robotPath": {
          "type": "string",
          "default": "",
          "description": "Trusted workspaces only: path to ROBOT CLI or JAR. When empty, ROBOT is resolved from PATH."
        },
        "ontocode.diagnostics.rules": {
          "type": "object",
          "default": {},
          "description": "Per-rule diagnostic overrides (enabled, severity). Mirrors `.ontocore/diagnostics.toml` [rules.*] entries; file config takes precedence when present."
        }
      }
    }
  },
  "scripts": {
    "build:webview": "npm --prefix webview-ui ci && npm --prefix webview-ui run build",
    "compile": "npm run build:webview && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "npm run compile && rm -rf dist-test && tsc -p tsconfig.test.json && node --test dist-test/**/*.test.js dist-test/**/*.e2e.test.js dist-test/**/*.guard.test.js",
    "compile:vscode-test": "tsc -p tsconfig.vscode-test.json",
    "test:vscode": "node out/test/runVscodeTest.js",
    "package": "npm run compile && vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "mocha": "^10.8.2",
    "typescript": "^5.3.3"
  }
}
