@prefix ex: <http://example.org/reasoner-unsat#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/reasoner-unsat> a owl:Ontology ;
    rdfs:label "Unsatisfiable EL fixture" .

ex:A a owl:Class ;
    rdfs:label "A" .

# Named class explicitly ⊑ ⊥ so adapters can expand descendants even when
# Ontologos only reports owl:Nothing in taxonomy.unsatisfiable.
ex:B a owl:Class ;
    rdfs:label "B" ;
    rdfs:subClassOf owl:Nothing .

ex:Invalid a owl:Class ;
    rdfs:label "Invalid" ;
    rdfs:subClassOf ex:A , ex:B .
